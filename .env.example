# Copy to a local secret file yourself. Do not give real values to Claude Code.
APP_ENV=development
APP_BASE_URL=http://localhost:3000
APP_LOG_LEVEL=info

DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_terminal
CACHE_URL=

# Verify current official endpoint values during implementation.
POLYMARKET_GAMMA_BASE_URL=
POLYMARKET_DATA_BASE_URL=
POLYMARKET_CLOB_BASE_URL=
POLYMARKET_MARKET_WS_URL=
POLYMARKET_USER_WS_URL=
POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=

# Non-secret public identifier (safe to share; confirmed by owner 2026-06-22)
POLYMARKET_BUILDER_CODE=0xe6121e8b7691171b67b6063142c42bfbf8ecf86b1b891bdf52f17d1aecea6be0

# Session configuration (7 days default; shorten in staging if desired)
SESSION_TTL_SECONDS=604800

# Secrets. Keep outside the repository and outside Claude-readable files.
# Required only when FEATURE_RELAYER=true. Builder creds are backend-only.
POLYMARKET_RELAYER_URL=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
# AES-256-GCM key for encrypting per-user L2 CLOB credentials in DB.
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_MASTER_KEY=REPLACE_ME_64_CHAR_HEX
SESSION_SECRET=
# Secret for /api/admin/trading/* kill-switch endpoints. Min 16 chars.
# Generate with: openssl rand -base64 32
TRADING_ADMIN_SECRET=REPLACE_ME_AT_LEAST_16_CHARS

# Optional providers; architecture owner must approve before adoption.
WALLET_CONNECT_PROJECT_ID=
SENTRY_DSN=
ANALYTICS_WRITE_KEY=
NOTIFICATION_PROVIDER_TOKEN=

# ── AI strategy generation (Anthropic) ──────────────────────────────────────
# Secret. Set the real key yourself; never commit it or share it with tooling.
# FEATURE_AI_CHAT=true refuses to boot without a key (fail-closed).
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
FEATURE_AI_CHAT=false
# Open beta: auto-allowlist every wallet that completes EIP-712 sign-in.
FEATURE_OPEN_BETA=false

# Safety switches
FEATURE_LIVE_TRADING=false
FEATURE_CONDITIONAL_RULES=true
FEATURE_CONDITIONAL_LIVE_EXECUTION=false
FEATURE_RELAYER=false
# Multi-chain deposits via the Polymarket Bridge (defaults ON — addresses can
# only deposit into the user's own wallet).
FEATURE_BRIDGE_FUNDING=true
# Withdrawals (to the login wallet only). Move real money and require the relayer
# stack (FEATURE_RELAYER=true → FEATURE_PRIVY_SIGNING + POLYMARKET_RELAYER_URL +
# POLYGON_RPC_URL). FEATURE_BRIDGE_WITHDRAWALS additionally needs WALLET_WITHDRAW.
FEATURE_WALLET_WITHDRAW=false
FEATURE_BRIDGE_WITHDRAWALS=false
# Server-side ("sign once") signing. When true, requires the Privy creds below
# (or, in a non-production env, MOCK_SIGNER_PRIVATE_KEY for the dry-run).
FEATURE_PRIVY_SIGNING=false
CLOSED_BETA_ALLOWLIST=

# ── Privy embedded-wallet signing (only needed when FEATURE_PRIVY_SIGNING=true) ──
# The raw private key NEVER touches this app — Privy holds it in a secure enclave.
# These are app credentials + references only. Keep app secret + authorization key
# in a secrets manager; use separate staging/production keys.
PRIVY_APP_ID=
PRIVY_APP_SECRET=REPLACE_ME_SECRET
PRIVY_AUTHORIZATION_KEY=REPLACE_ME_SECRET
PRIVY_KEY_QUORUM_ID=
# Privy policy id allowlisting ONLY Polymarket contracts (destination backstop).
PRIVY_TRADING_POLICY_ID=
# Polygon RPC for reading allowances / building bootstrap txs (allowance bootstrap).
POLYGON_RPC_URL=
# Trading-session guardrails.
SESSION_SIGNER_TTL_SECONDS=86400
ORDER_RATE_LIMIT_PER_MIN=10
# NON-PRODUCTION ONLY: a throwaway local key the mock signer uses for the live-OFF
# dry-run (lets the whole server-signing path run without Privy). NEVER set in prod.
# Generate with: echo 0x$(openssl rand -hex 32)
MOCK_SIGNER_PRIVATE_KEY=

# Maker loop (shadow-only in dev; see .env.production.example for the ladder).
FEATURE_MAKER_LOOP=false
FEATURE_MAKER_LOOP_LIVE=false
