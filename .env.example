# Copy to a local secret file yourself. Do not give real values to Claude Code.
APP_ENV=development
APP_BASE_URL=http://localhost:3000
APP_LOG_LEVEL=info

DATABASE_URL=postgresql://user:password@localhost:5432/polymarket_terminal
CACHE_URL=

# Verify current official endpoint values during implementation.
POLYMARKET_GAMMA_BASE_URL=
POLYMARKET_DATA_BASE_URL=
POLYMARKET_CLOB_BASE_URL=
POLYMARKET_MARKET_WS_URL=
POLYMARKET_USER_WS_URL=
POLYMARKET_RELAYER_BASE_URL=
POLYGON_CHAIN_ID=137
POLYGON_RPC_URL=

# Non-secret identifier
POLYMARKET_BUILDER_CODE=

# Secrets. Keep outside the repository and outside Claude-readable files.
POLYMARKET_RELAYER_API_KEY=
POLYMARKET_RELAYER_API_KEY_ADDRESS=
APP_ENCRYPTION_MASTER_KEY=
SESSION_SECRET=

# Optional providers; architecture owner must approve before adoption.
WALLET_CONNECT_PROJECT_ID=
SENTRY_DSN=
ANALYTICS_WRITE_KEY=
NOTIFICATION_PROVIDER_TOKEN=

# Safety switches
FEATURE_LIVE_TRADING=false
FEATURE_CONDITIONAL_RULES=true
FEATURE_CONDITIONAL_LIVE_EXECUTION=false
FEATURE_RELAYER=false
CLOSED_BETA_ALLOWLIST=
