# Production env for docker-compose.prod.yml. Copy to .env.production and fill in.
# NEVER commit the filled file. Generate secrets with: openssl rand -hex 32

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_LOG_LEVEL=info
API_PORT=3001
# All-in-one deploy: web + API share one domain behind Caddy.
APP_BASE_URL=https://arima.finance
# Domain Caddy serves the stack on (A record → Lightsail static IP).
API_DOMAIN=arima.finance
# Same origin (web + /api behind one proxy) → first-party cookie, keep false.
COOKIE_CROSS_SITE=false

# ── Database (compose runs Postgres as the `postgres` service) ────────────────
POSTGRES_USER=mx2
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=polymarket_terminal
DATABASE_URL=postgresql://mx2:REPLACE_ME_STRONG_PASSWORD@postgres:5432/polymarket_terminal

# ── Secrets ──────────────────────────────────────────────────────────────────
APP_ENCRYPTION_MASTER_KEY=REPLACE_ME_64_CHAR_HEX
TRADING_ADMIN_SECRET=REPLACE_ME_AT_LEAST_16_CHARS

# ── Polymarket ───────────────────────────────────────────────────────────────
POLYMARKET_BUILDER_CODE=0xe6121e8b7691171b67b6063142c42bfbf8ecf86b1b891bdf52f17d1aecea6be0
# A Polygon mainnet RPC (Alchemy/Infura/Ankr/public). Needed for relayer activation/allowance reads.
POLYGON_RPC_URL=https://polygon-rpc.com
# Required only when FEATURE_RELAYER=true. Builder creds are backend-only.
POLYMARKET_RELAYER_URL=
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=

# ── Privy (server-side signing) ──────────────────────────────────────────────
PRIVY_APP_ID=cmqyxhu85006e0bl814gabi1s
PRIVY_APP_SECRET=REPLACE_ME_PRIVY_APP_SECRET
# Base64 PKCS8 P-256 authorization private key (from the Privy dashboard).
PRIVY_AUTHORIZATION_KEY=REPLACE_ME_PRIVY_AUTHORIZATION_KEY
# Key quorum id that owns provisioned wallets (the authorization key's quorum).
PRIVY_KEY_QUORUM_ID=REPLACE_ME_KEY_QUORUM_ID
# Run scripts/bootstrap-privy-policy.ts once, then paste the printed id here.
PRIVY_TRADING_POLICY_ID=

# ── Trading session guardrails ───────────────────────────────────────────────
SESSION_SIGNER_TTL_SECONDS=86400
ORDER_RATE_LIMIT_PER_MIN=10

# ── AI strategy generation (Anthropic) ───────────────────────────────────────
# Secret. Owner pastes the real key on the box by hand; never commit or share it.
# ⚠ The key ALONE does not enable AI. You must ALSO set FEATURE_AI_CHAT=true below,
#   then RECREATE the containers: docker compose -f docker-compose.prod.yml up -d
#   (a plain `restart`/reboot does NOT re-read this file).
#   Verify with: curl https://<api-domain>/api/feature-flags → "aiChat":true
# Paste the raw key with no quotes and no trailing whitespace.
# FEATURE_AI_CHAT=true refuses to boot without a key (fail-closed).
ANTHROPIC_API_KEY=
# Beta default (D-022): cheapest capable tier. Unset falls back to claude-sonnet-5.
AI_MODEL=claude-haiku-4-5

# ── Feature flags — START ALL FALSE. Flip per the Gate 6 runbook after staging. ─
FEATURE_PRIVY_SIGNING=false
FEATURE_LIVE_TRADING=false
FEATURE_CONDITIONAL_RULES=true
FEATURE_CONDITIONAL_LIVE_EXECUTION=false
FEATURE_RELAYER=false
# Deposit-only Bridge funding is the exception: it defaults ON (D-033) because
# generated addresses can only deposit into the user's own wallet. Set false to
# opt out.
FEATURE_BRIDGE_FUNDING=true

# ── Withdrawals (owner-approved gate, D-034) ──────────────────────────────────
# Real money leaves the deposit wallet — but ONLY to the session user's own login
# wallet (destination is server-resolved, never client input; R-031). Kept false
# in this template so it always boots. To ENABLE on a relayer-backed deployment,
# set these to true TOGETHER WITH the relayer stack (config refuses to boot
# half-enabled): FEATURE_PRIVY_SIGNING=true, FEATURE_RELAYER=true, plus
# POLYMARKET_RELAYER_URL, POLYGON_RPC_URL and the Privy creds above.
#   FEATURE_WALLET_WITHDRAW=true     → direct Polygon withdrawal (gasless, pUSD → login wallet)
#   FEATURE_BRIDGE_WITHDRAWALS=true  → also cross-chain (Base/Arbitrum/Ethereum) via the Bridge
#                                      (requires FEATURE_WALLET_WITHDRAW=true)
# Validate with a low-value transfer on staging before broad use.
FEATURE_WALLET_WITHDRAW=false
FEATURE_BRIDGE_WITHDRAWALS=false
# Public NL→Smart Order generation. Requires ANTHROPIC_API_KEY above.
# Value must be the exact lowercase string true/false — anything else (1, TRUE, yes,
# quotes, trailing space) crashes the API on boot (fail-closed config).
FEATURE_AI_CHAT=false
# Open beta: auto-allowlist every wallet that completes sign-in.
FEATURE_OPEN_BETA=false

# Beta access is DB-backed (allowlist table), not env-backed:
# seed wallets with `pnpm db:seed:allowlist 0xYourEoaAddress`.

# ── Maker loop (RFC-0003) ─────────────────────────────────────────────────────
# FEATURE_MAKER_LOOP enables quote_loop creation, the farming cockpit, and the
# worker's SHADOW quoter (records intended quotes; places nothing, moves no
# funds). FEATURE_MAKER_LOOP_LIVE additionally requires FEATURE_LIVE_TRADING,
# FEATURE_PRIVY_SIGNING, FEATURE_RELAYER and BOTH adapter addresses below —
# config refuses to boot half-enabled. Addresses have NO defaults on purpose:
# official sources disagree (R-028) — run
#   pnpm --filter @mx2/api exec tsx src/scripts/verify-ctf-adapters.ts
# and record the result in docs/INTEGRATION_VERIFIED.md first.
FEATURE_MAKER_LOOP=false
FEATURE_MAKER_LOOP_LIVE=false
# CTF_ADAPTER_ADDRESS=
# NEG_RISK_CTF_ADAPTER_ADDRESS=
