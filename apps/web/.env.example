# Frontend (apps/web) local config. Copy to apps/web/.env.local if you need overrides.

# Where the Next server proxies /api and health probes (the backend, apps/api).
API_PROXY_TARGET=http://localhost:3001

# WalletConnect project id. MetaMask (injected) works without a real id, but the
# WalletConnect option needs one from https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=MX2_LOCAL_DEV_PLACEHOLDER

# Optional Polygon RPC for wagmi (falls back to a public default if unset).
NEXT_PUBLIC_POLYGON_RPC_URL=
